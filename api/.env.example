# MongoDB — shared cinefiller cluster
MONGODB_URI=mongodb+srv://user:pass@cinefiller-cluster.mongodb.net/
# Shared identity DB (SSO across assistive verticals) — users live here
IDENTITY_DB=assistive_identity
# Per-vertical DB — this app's domain + social data
MONGODB_DB=beekeeper

DEBUG=True
API_HOST=0.0.0.0
API_PORT=2020
CORS_ORIGINS=http://localhost:2000

# JWT — SSO signing key shared across assistive verticals.
# init_core refuses to start when ENV=production and this is left as the placeholder.
JWT_SECRET_KEY=your-secret-key-here-change-in-production
# ENV=production

# Anthropic (Claude chat + vision)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Shared weather service (VRUsafety hazard-service); leave blank to skip
WEATHER_SERVICE_URL=

# Bunny CDN — shared hyperlocal zone, beekeeper folder namespace
BUNNY_API_KEY=
BUNNY_STORAGE_ZONE=hyperlocal
BUNNY_CDN_URL=https://hyperlocal.b-cdn.net
